SELECT * FROM students;

SELECT name,(math + science + programming)/3.0 AS avg_marks FROM students;

SELECT name,(math + science + programming)/3.0 AS avg_marks FROM students ORDER BY avg_marks DESC;

SELECT department, AVG((math + science + programming)/3.0) AS dept_avg FROM students GROUP BY department;

SELECT * FROM students WHERE math < 60 OR science < 60 OR programming < 60;

SELECT AVG((math + science + programming)/3.0) AS class_avg FROM students;
